<section class="kino-cards page-width">
  {% if section.settings.heading != blank %}<h2 class="kino-cards__title">{{ section.settings.heading }}</h2>{% endif %}
  <div class="kino-cards__grid">
    {% for block in section.blocks %}
      <article class="kino-card" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.title }}</h3>
        <div class="rte">{{ block.settings.text }}</div>
      </article>
    {% endfor %}
  </div>
</section>
{% schema %}
{
  "name": "Kino — Tres columnas",
  "settings": [ { "type": "text", "id": "heading", "label": "Título de la sección", "default": "Beneficios" } ],
  "blocks": [
    { "type": "card", "name": "Columna", "settings": [
      { "type": "text", "id": "title", "label": "Título", "default": "Título" },
      { "type": "richtext", "id": "text", "label": "Texto", "default": "<p>Contenido de la columna.</p>" }
    ] }
  ],
  "max_blocks": 3,
  "enabled_on": { "templates": ["*"] },
  "presets": [{ "name": "Kino — Tres columnas", "category": "Kino", "blocks": [ { "type": "card" }, { "type": "card" }, { "type": "card" } ] }]
}
{% endschema %}
