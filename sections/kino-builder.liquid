<section class="kino-builder page-width">
  {% if section.blocks.size == 0 %}<div class="kino-placeholder">Agrega bloques en el panel →</div>{% endif %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'hero' %}
        <section class="kino-hero"><h1 class="kino-title">{{ block.settings.title | default: page.title }}</h1>{% if block.settings.subtitle != blank %}<p class="kino-subtitle">{{ block.settings.subtitle }}</p>{% endif %}</section>
      {% when 'image_text' %}
        {%- assign layout = block.settings.layout -%}
        <section class="kino-split">
          <div class="kino-split__grid {% if layout == 'image_left' %}img-left{% else %}img-right{% endif %}">
            <div class="kino-split__media">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
              {% else %}<div class="kino-placeholder">Sube una imagen</div>{% endif %}
            </div>
            <div class="kino-split__content">
              {% if block.settings.heading != blank %}<h2>{{ block.settings.heading }}</h2>{% endif %}
              <div class="rte">{{ block.settings.text }}</div>
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a class="button" href="{{ block.settings.button_link }}">{{ block.settings.button_label }}</a>
              {% endif %}
            </div>
          </div>
        </section>
      {% when 'banner' %}
        <section class="kino-banner"><p class="kino-banner__text">{{ block.settings.text }}</p></section>
      {% when 'columns' %}
        <section class="kino-cards">
          <div class="kino-cards__grid">
            {% if block.settings.title1 != blank or block.settings.text1 != blank %}
              <article class="kino-card"><h3>{{ block.settings.title1 }}</h3><div class="rte">{{ block.settings.text1 }}</div></article>
            {% endif %}
            {% if block.settings.title2 != blank or block.settings.text2 != blank %}
              <article class="kino-card"><h3>{{ block.settings.title2 }}</h3><div class="rte">{{ block.settings.text2 }}</div></article>
            {% endif %}
            {% if block.settings.title3 != blank or block.settings.text3 != blank %}
              <article class="kino-card"><h3>{{ block.settings.title3 }}</h3><div class="rte">{{ block.settings.text3 }}</div></article>
            {% endif %}
          </div>
        </section>
    {% endcase %}
  {% endfor %}
</section>
{% schema %}
{
  "name": "Kino — Builder (bloques)",
  "blocks": [
    { "type": "hero", "name": "Hero (título)", "settings": [
      { "type": "text", "id": "title", "label": "Título", "default": "Título de la sección" },
      { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Opcional" }
    ] },
    { "type": "image_text", "name": "Imagen + Texto", "settings": [
      { "type": "image_picker", "id": "image", "label": "Imagen" },
      { "type": "select", "id": "layout", "label": "Diseño", "default": "image_left",
        "options": [
          { "value": "image_left", "label": "Imagen izquierda" },
          { "value": "text_left", "label": "Texto izquierda (imagen derecha)" }
        ] },
      { "type": "text", "id": "heading", "label": "Título", "default": "Título" },
      { "type": "richtext", "id": "text", "label": "Texto", "default": "<p>Contenido</p>" },
      { "type": "text", "id": "button_label", "label": "Texto botón", "default": "Ver más" },
      { "type": "url", "id": "button_link", "label": "Enlace botón" }
    ] },
    { "type": "banner", "name": "Banner de texto", "settings": [
      { "type": "text", "id": "text", "label": "Texto", "default": "Texto del banner" },
      { "type": "color", "id": "bg_color", "label": "Color de fondo", "default": "#283e61" },
      { "type": "color", "id": "text_color", "label": "Color del texto", "default": "#ffffff" }
    ] },
    { "type": "columns", "name": "Tres columnas", "settings": [
      { "type": "text", "id": "title1", "label": "Título 1", "default": "Título 1" },
      { "type": "richtext", "id": "text1", "label": "Texto 1", "default": "<p>Texto 1</p>" },
      { "type": "text", "id": "title2", "label": "Título 2", "default": "Título 2" },
      { "type": "richtext", "id": "text2", "label": "Texto 2", "default": "<p>Texto 2</p>" },
      { "type": "text", "id": "title3", "label": "Título 3", "default": "Título 3" },
      { "type": "richtext", "id": "text3", "label": "Texto 3", "default": "<p>Texto 3</p>" }
    ] }
  ],
  "enabled_on": { "templates": ["*"] },
  "presets": [{ "name": "Kino — Builder (bloques)", "category": "Kino" }]
}
{% endschema %}
